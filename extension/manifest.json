{
  "manifest_version": 3,

  "name": "AI Phishing Guard",
  "version": "3.1",
  "description": "AI-powered real-time phishing detection and blocking extension.",

  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:5000/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
  {
    "matches": ["http://*/*", "https://*/*"],
    "exclude_matches": [
      "*://chrome.google.com/*"
    ],
    "js": ["content.js"],
    "run_at": "document_idle"
  }
],

  "action": {
    "default_title": "AI Phishing Guard",
    "default_popup": "popup.html"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "dashboard.html",
        "dashboard.js",
        "dashboard.css"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}